{% extends 'adm/adm_layout.njk' %}

{% block head %}
<title>New Recipe</title>
{% endblock %}

{% block content %}
        <form  method="POST" action="/admin/recipes" >

    <div class="create_recipe">

        <p class="title">Criando receita</p> <input type="submit" value="Salvar receita">

        <div class="item">
             <p class="subtitle">imagem da receita</p>
             <input type="url" name="image" placeholder="Insira uma URL válida" value="">
        </div>
         
        <div class="item">
            <div id="ingredients">
             <div class="subtitle">Ingredientes</div>
                <div class="ingredient">
                    <input type="text[]" name="ingredients" value=""> 
                </div>
            </div>
             <span class="add_ingredient add_button">Adicionar novo ingrediente</span>
        </div>
        
        <div class="item">
            <div id="preparations">
             <p class="subtitle">Modo de preparo</p>
                <div class="preparation">
                    <input type="text[]" name="preparation" value="">
                </div>
            </div>
             <span class="add_step add_button">Adicionar novo passo</span>
        </div>

        <div class="item">
             <p class="subtitle">Informações adicionais</p>
             <textarea name="information" cols="30" rows="10" value=""></textarea>
        </div>

    </div>

        </form>
    <script src="/addbuttonscript.js"></script>
{% endblock %}